<launch>

  <node pkg="move_base"
        type="move_base"
        name="move_base"
        output="screen">

    <rosparam file="$(find robot_bringup)/config/costmap_common.yaml" command="load"/>
    <rosparam file="$(find robot_bringup)/config/local_costmap.yaml" command="load"/>
    <rosparam file="$(find robot_bringup)/config/global_costmap.yaml" command="load"/>
    <rosparam file="$(find robot_bringup)/config/base_local_planner.yaml" command="load"/>

  </node>

</launch>
